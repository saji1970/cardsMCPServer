{
  "name": "cards-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for Card Services, Rewards, and Promotions",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && vite build --config frontend/vite.config.ts",
    "start": "node dist/server.js",
    "start:http": "node dist/server-http.js",
    "dev": "ts-node src/server.ts",
    "dev:http": "ts-node src/server-http.ts",
    "dev:ui": "vite --config frontend/vite.config.ts",
    "test": "jest --config jest.config.js"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vite": "^8.0.8"
  }
}
