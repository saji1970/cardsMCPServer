{
  "openapi": "3.0.3",
  "info": {
    "title": "Tiny Store Sample",
    "version": "1.0.0",
    "description": "Minimal OpenAPI sample for MCP dynamic tools (use with a mock server or replace servers.url)."
  },
  "servers": [{ "url": "https://jsonplaceholder.typicode.com" }],
  "paths": {
    "/posts": {
      "get": {
        "operationId": "listPosts",
        "summary": "List posts",
        "parameters": [
          {
            "name": "userId",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" },
            "description": "Filter by author user id"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/posts/{id}": {
      "get": {
        "operationId": "getPostById",
        "summary": "Get post by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Post id"
          }
        ],
        "responses": {
          "200": { "description": "OK" },
          "404": { "description": "Not found" }
        }
      }
    }
  }
}
