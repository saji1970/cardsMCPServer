PORT=3001
CARD_API_BASE_URL=http://localhost:4001/api/cards
REWARDS_API_BASE_URL=http://localhost:4002/api/rewards
PROMO_API_BASE_URL=http://localhost:4003/api/promotions
AUTH_TOKEN=changeme
LOG_LEVEL=info
CACHE_TTL_SECONDS=300
SIMULATION_MODE=false

# HTTP admin UI + sandbox (Railway uses start:http). Optional: protect admin routes.
# ADMIN_API_TOKEN=your-secret
# SANDBOX_PUBLIC=true

# OpenAPI → MCP tools (optional). Semicolon- or comma-separated paths to OpenAPI 3.x JSON/YAML files.
# Paths resolve from the process working directory, then from the mcp-server package folder.
# OPENAPI_SPEC_PATHS=openapi-samples/tiny-store.json
# OPENAPI_HTTP_BEARER=
# OPENAPI_HTTP_HEADERS_JSON={"X-Custom-Header":"value"}
# OPENAPI_SERVER_VERSION=v1
